#!/usr/bin/env python3
import json
import sys


def is_image_generation(tool):
    if isinstance(tool, str):
        return tool == "image_generation"
    if isinstance(tool, dict):
        return tool.get("type") == "image_generation" or tool.get("name") == "image_generation"
    return False


def sanitize_tool_choice(tool_choice):
    if tool_choice == "image_generation":
        return "auto"
    if not isinstance(tool_choice, dict):
        return tool_choice
    if tool_choice.get("type") == "image_generation" or tool_choice.get("name") == "image_generation":
        return "auto"
    nested = tool_choice.get("tool")
    if isinstance(nested, dict) and (nested.get("type") == "image_generation" or nested.get("name") == "image_generation"):
        return "auto"
    return tool_choice


request = json.load(sys.stdin)
content_type = (request.get("content_type") or "").strip().lower()
if content_type != "application/json" and not content_type.startswith("application/json;"):
    json.dump(request, sys.stdout, separators=(",", ":"))
    sys.exit(0)

body = json.loads(request.get("body") or "null")
if not isinstance(body, dict):
    json.dump(request, sys.stdout, separators=(",", ":"))
    sys.exit(0)

changed = False
tools = body.get("tools")
if isinstance(tools, list):
    next_tools = []
    for tool in tools:
        if is_image_generation(tool):
            changed = True
            continue
        next_tools.append(tool)
    body["tools"] = next_tools

if "tool_choice" in body:
    sanitized = sanitize_tool_choice(body["tool_choice"])
    if sanitized != body["tool_choice"]:
        body["tool_choice"] = sanitized
        changed = True

if changed:
    request.setdefault("headers", {})["Content-Type"] = ["application/json"]
    request["body"] = json.dumps(body, separators=(",", ":"))
    request["content_type"] = "application/json"

json.dump(request, sys.stdout, separators=(",", ":"))
